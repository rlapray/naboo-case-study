{
  "name": "naboo-case-study",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "check": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest",
    "verify": "pnpm lint && pnpm check",
    "verify:test": "vitest run",
    "coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:server": "next build && next start -p 3002",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "e2e:report": "playwright show-report",
    "e2e:codegen": "playwright codegen http://localhost:3001",
    "seed": "tsx scripts/seed.ts",
    "start:db": "docker-compose up -d",
    "stop:db": "docker-compose stop",
    "stop:db:rm": "docker-compose down",
    "prepare": "lefthook install"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@mantine/core": "^9.1.0",
    "@mantine/form": "^9.1.0",
    "@mantine/hooks": "^9.1.0",
    "@tabler/icons-react": "^3.41.1",
    "bcrypt": "^6.0.0",
    "cookie": "^1.1.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.5.0",
    "next": "^16.2.4",
    "react": "^19.2",
    "react-dom": "^19.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.4.3",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2",
    "@types/react-dom": "^19.2",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "dotenv": "^17.4.2",
    "eslint": "^10.2.1",
    "eslint-config-next": "^16.2.4",
    "eslint-import-resolver-typescript": "^4.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-sonarjs": "^4.0.3",
    "jsdom": "^29.0.2",
    "lefthook": "^2.1.6",
    "mongodb-memory-server": "^11.0.0",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "tsx": "^4.21.0",
    "typescript": "6.0.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "sharp"
    ],
    "auditConfig": {
      "ignoreCves": [],
      "ignoreGhsas": []
    },
    "overrides": {
      "minimatch@9": "^9.0.7",
      "postcss": "^8.5.10"
    }
  },
  "comments": {
    "pnpm.overrides.postcss": "Force postcss >=8.5.10 — fix GHSA-qx2v-qp2m-jg93 (XSS via </style> dans CSS Stringify). Transitive de next@16.2.4 encore pinné <8.5.10. À retirer quand Next bumpera postcss. Source: https://github.com/advisories/GHSA-qx2v-qp2m-jg93"
  }
}
