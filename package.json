        "GHSA-9ppj-qmqm-q256",
        "GHSA-f82v-jwr5-mffw",
        "GHSA-fq54-2j52-jc42",
        "GHSA-fr5h-rqp8-mj6g",
        "GHSA-h25m-26qc-wcjf",
        "GHSA-mwv6-3258-q52c",
        "GHSA-q4gf-8mx6-v5v3",
