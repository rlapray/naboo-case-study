{
  "name": "naboo-case-study",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "check": "tsc --noEmit",
    "lint": "next lint",
    "test": "vitest",
    "verify": "pnpm lint && pnpm check",
    "verify:test": "vitest run",
    "e2e": "playwright test",
    "e2e:server": "next build && next start -p 3002",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "e2e:report": "playwright show-report",
    "e2e:codegen": "playwright codegen http://localhost:3001",
    "seed": "tsx scripts/seed.ts",
    "start:db": "docker-compose up -d",
    "stop:db": "docker-compose stop",
    "stop:db:rm": "docker-compose down",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@mantine/core": "^8.0.0",
    "@mantine/form": "^8.0.0",
    "@mantine/hooks": "^8.0.0",
    "@tabler/icons-react": "^3.41.1",
    "bcrypt": "^6.0.0",
    "cookie": "^1.1.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.23.0",
    "next": "^15.3.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.4.3",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie": "^1.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "20.4.10",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^4.0.3",
    "dotenv": "^17.4.2",
    "eslint": "8.45.0",
    "eslint-config-next": "^15.3.1",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "jsdom": "^22.1.0",
    "lefthook": "^2.1.6",
    "mongodb-memory-server": "^9.5.0",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "tsx": "^4.21.0",
    "typescript": "5.1.6",
    "vitest": "^0.33.0"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "sharp"
    ],
    "auditConfig": {
      "ignoreCves": [],
      "ignoreGhsas": []
    }
  }
}
