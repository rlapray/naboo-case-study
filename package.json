{
  "name": "naboo-case-study",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "check": "tsc --noEmit",
    "lint": "next lint",
    "test": "vitest",
    "verify": "pnpm lint && pnpm check",
    "verify:test": "vitest run",
    "e2e": "playwright test",
    "e2e:server": "next build && next start -p 3002",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "e2e:report": "playwright show-report",
    "e2e:codegen": "playwright codegen http://localhost:3001",
    "seed": "tsx scripts/seed.ts",
    "start:db": "docker-compose up -d",
    "stop:db": "docker-compose stop",
    "stop:db:rm": "docker-compose down",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@emotion/react": "^11.11.1",
    "@emotion/server": "^11.11.0",
    "@mantine/core": "^6.0.16",
    "@mantine/form": "^6.0.16",
    "@mantine/hooks": "^6.0.16",
    "@mantine/next": "^6.0.16",
    "@tabler/icons-react": "^2.25.0",
    "bcrypt": "^6.0.0",
    "cookie": "^1.1.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^7.8.9",
    "next": "13.4.19",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.4.3",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie": "^1.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "20.4.10",
    "@types/react": "18.2.79",
    "@types/react-dom": "18.2.25",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^4.0.3",
    "dotenv": "^17.4.2",
    "eslint": "8.45.0",
    "eslint-config-next": "13.4.19",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "jsdom": "^22.1.0",
    "lefthook": "^2.1.6",
    "mongodb-memory-server": "^9.5.0",
    "tsx": "^4.21.0",
    "typescript": "5.1.6",
    "vitest": "^0.33.0"
  },
  "pnpm": {
    "auditConfig": {
      "ignoreCves": [],
      "ignoreGhsas": [
        "GHSA-34x7-hfp2-rc4v",
        "GHSA-5j59-xgg2-r9c4",
        "GHSA-77r5-gw3j-2mpf",
        "GHSA-7gfc-8cq8-jh5f",
        "GHSA-83g3-92jg-28cx",
